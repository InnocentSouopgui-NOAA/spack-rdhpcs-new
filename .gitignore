# Spack tool clone -- cloned separately per control/<year>/INSTALL.md,
# pinned to whichever branch/tag that year's INSTALL.md specifies. Not
# vendored into this repo.
control/*/spack/

# Host-specific: written by `spack compiler find` on whichever machine
# actually runs the install. Not portable, not something to commit.
control/*/common/config/

# Generated by bootstrap.sh -- rendered Spack config and init.sh with a
# concrete install root baked in. Regenerate with bootstrap.sh, don't
# hand-edit or commit.
control/*/rendered/

# Claude Code's local session settings for this working directory.
.claude/
